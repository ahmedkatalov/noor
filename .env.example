# ============================================================
#  Production env для docker-compose.prod.yml
#  Скопируй в .env и заполни значения:  cp .env.example .env
#  Файл .env НЕ коммитится (он в .gitignore).
# ============================================================

# Домен. A-запись DNS (и noorcoffee.ru, и www.noorcoffee.ru)
# должна указывать на IP этого сервера.
DOMAIN=noorcoffee.ru

# Email для уведомлений Let's Encrypt (об истечении сертификата и т.п.)
ACME_EMAIL=admin@noorcoffee.ru

# --- PostgreSQL ---
POSTGRES_USER=postgres
# ОБЯЗАТЕЛЬНО смени на длинный случайный пароль:
POSTGRES_PASSWORD=change_me_to_a_long_random_password
POSTGRES_DB=coffeeshop

# --- Админка ---
# Ключ для входа в /admin и /staff. ОБЯЗАТЕЛЬНО смени на случайный.
ADMIN_TOKEN=change_me_to_a_secret_token

# --- Значения по умолчанию для витрины ---
# (потом можно менять прямо в админке -> "Внешний вид")
BRAND_NAME=Noor Coffee
WHATSAPP_PHONE=79284338787
CURRENCY=₽
